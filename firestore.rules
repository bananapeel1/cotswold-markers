rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Scan counts — readable by anyone, writable only by server (admin SDK bypasses rules)
    match /scanCounts/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // Admin-only collections — server SDK bypasses these rules,
    // but this blocks any direct client-side access
    match /markers/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /stories/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /businesses/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /pois/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /siteSettings/{doc} {
      allow read: if true;
      allow write: if false;
    }

    match /allowedAdmins/{doc} {
      allow read, write: if false;
    }

    // Trail conditions — authenticated users can create, anyone can read
    match /trailConditions/{doc} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
